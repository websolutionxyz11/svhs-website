{
  "framework": "tanstack-start",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/favicon.png" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" }
  ]
}